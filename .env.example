# Copy to .env.local for development. None of these ship to the client
# unless explicitly prefixed with NEXT_PUBLIC_.

# --- Subpath deployment ---
# When deployed behind a rewrite from masonborchard.com/synapse-conference-prototype
# set this to that path. Leave blank for local dev so the site lives at /.
NEXT_PUBLIC_BASE_PATH=

# --- Concierge (Ada) ---
# Ada supports Anthropic first (per the committee spec), then OpenAI as
# a fallback so development can proceed with whichever key is handy.
# If both are set, Anthropic wins.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model id override. Defaults are picked per provider at runtime.
CONCIERGE_MODEL_ID=

# --- Registration pipeline ---
# Service account JSON, base64-encoded. Without it, submissions log to
# stdout and still return a confirmation id so dev flows work cleanly.
GOOGLE_SERVICE_ACCOUNT_B64=
GOOGLE_SHEET_ID=

# --- Transactional email ---
# Optional. Confirmation emails are silently skipped when unset.
RESEND_API_KEY=
RESEND_FROM="The Synapse <hello@thesynapse.example>"

# --- Donations ---
# DONATION_PROVIDER picks which backend the /api/donate route uses:
# stripe (default), paypal, patreon, donorbox, none.
# When the committee picks a permanent provider via Applied Love Labs,
# see src/lib/donations/README.md for the swap-in walkthrough.
DONATION_PROVIDER=stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# For non-Stripe embeds (Donorbox / Patreon / PayPal), the module reads
# DONATION_EMBED_URL instead of contacting an API at all.
DONATION_EMBED_URL=

# --- Rate limiting ---
# Upstash Redis fronts every /api route. Falls back to an in-memory
# sliding-window limiter when unset (fine for dev, not for prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Misc ---
NEXT_PUBLIC_SITE_URL=https://masonborchard.com
